# Trace 后端环境变量示例
# Copy this file to .env and fill in your values

# Database configuration
DB_PASSWORD=your-secure-db-password

# JWT secret key - generate with: openssl rand -hex 32
SECRET_KEY=your-random-secret-key-change-in-production

# Flask environment - development/production
FLASK_ENV=production

# ---------------------------------------------------------
# Third-party API credentials - fill in as needed
# ---------------------------------------------------------

# Alibaba Cloud SMS (for verification code)
SMS_ACCESS_KEY_ID=
SMS_SECRET_ACCESS_KEY=
SMS_SIGN_NAME=
SMS_TEMPLATE_CODE=

# WeChat OAuth login
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_REDIRECT_URI=

# AI API configuration
AI_DEFAULT_PROVIDER=ernie
AI_ERNIE_API_KEY=
AI_ERNIE_SECRET_KEY=
