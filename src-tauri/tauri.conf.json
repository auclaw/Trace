{
  "$schema": "https://schema.tauri.app/config/1.0.0",
  "package": {
    "productName": "rize-chinese",
    "version": "1.0.0"
  },
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "msi", "appimage"],
    "identifier": "com.yourname.rizechinese",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "security": {
    "csp": null
  }
}
