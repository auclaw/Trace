    "i18next": "^26.0.4",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.8.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^17.0.2",
    "react-router-dom": "^7.13.1",
