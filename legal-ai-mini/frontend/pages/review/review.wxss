.container {
  padding: 30rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.input-area {
  background: white;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
}

.input-area textarea {
  width: 100%;
  min-height: 300rpx;
  font-size: 28rpx;
  line-height: 1.6;
}

.remaining-hint {
  font-size: 26rpx;
  color: #666;
  text-align: center;
  margin-bottom: 30rpx;
}

.remaining-hint .number {
  color: #1677ff;
  font-weight: bold;
  font-size: 30rpx;
}

.remaining-hint.no-quota {
  color: #ff4d4f;
}

.submit-btn {
  background: #1677ff;
  color: white;
  border-radius: 50rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  margin-bottom: 40rpx;
}

.submit-btn.disabled {
  background: #ccc;
}

.result-area {
  background: white;
  border-radius: 12rpx;
  padding: 30rpx;
}

.result-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.result-content {
  font-size: 28rpx;
  line-height: 1.8;
  color: #444;
  white-space: pre-wrap;
}

.loading {
  text-align: center;
  color: #999;
  font-size: 26rpx;
  padding: 40rpx 0;
}
