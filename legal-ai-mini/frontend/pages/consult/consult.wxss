.container {
  padding: 30rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f4ff 0%, #f5f5f5 100%);
}

.input-area {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.08);
}

.input-area textarea {
  width: 100%;
  min-height: 240rpx;
  font-size: 30rpx;
  line-height: 1.6;
  color: #2c3e50;
}

.remaining-hint {
  font-size: 26rpx;
  color: #666;
  text-align: center;
  margin-bottom: 30rpx;
}

.remaining-hint .number {
  color: #667eea;
  font-weight: bold;
  font-size: 32rpx;
}

.remaining-hint.no-quota {
  color: #ff4d4f;
}

.submit-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-radius: 50rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.3);
}

.submit-btn.disabled {
  background: #ccc;
  box-shadow: none;
}

.result-area {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.08);
}

.result-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2c3e50;
  margin-bottom: 20rpx;
}

.result-content {
  font-size: 30rpx;
  line-height: 1.8;
  color: #4a4a4a;
  white-space: pre-wrap;
}

.loading {
  text-align: center;
  color: #95a5a6;
  font-size: 28rpx;
  padding: 40rpx 0;
}
