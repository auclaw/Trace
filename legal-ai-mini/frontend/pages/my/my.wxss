.container {
  padding: 30rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f4ff 0%, #f5f5f5 100%);
}

.user-card {
  background: white;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.08);
}

.user-card .avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 50rpx;
  margin-right: 24rpx;
}

.user-card .user-info .nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #2c3e50;
  margin-bottom: 12rpx;
}

.user-card .user-info .vip-info {
  font-size: 28rpx;
  color: #666;
}

.user-card .user-info .vip-info .vip-tag {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  margin-right: 12rpx;
}

.user-card .user-info .vip-info .not-vip {
  color: #999;
}

.menu-list {
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.08);
  margin-bottom: 30rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item .menu-icon {
  font-size: 40rpx;
  margin-right: 24rpx;
}

.menu-item .menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #2c3e50;
}

.menu-item .arrow {
  color: #bdc3c7;
  font-size: 32rpx;
}

.price-list {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.08);
  margin-bottom: 30rpx;
}

.price-list .title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2c3e50;
  margin-bottom: 24rpx;
}

.price-card {
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  position: relative;
  display: flex;
  align-items: center;
}

.price-card.selected {
  border-color: #667eea;
  background: #f0f4ff;
}

.price-card .price-tag {
  position: absolute;
  top: -10rpx;
  left: 20rpx;
  background: #667eea;
  color: white;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.price-card .price-tag.discount {
  background: #f0932b;
}

.price-card .info {
  flex: 1;
}

.price-card .info .name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2c3e50;
  margin-bottom: 8rpx;
}

.price-card .info .price {
  font-size: 36rpx;
  font-weight: bold;
  color: #e74c3c;
}

.price-card .checkmark {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: #667eea;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.buy-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-radius: 50rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  margin-top: 20rpx;
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.3);
}

.disclaimer {
  background: #fff8e1;
  border: 1rpx solid #ffecb3;
  border-radius: 16rpx;
  padding: 20rpx;
}

.disclaimer .disclaimer-text {
  font-size: 24rpx;
  line-height: 1.6;
  color: #998000;
}
