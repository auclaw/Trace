.container {
  padding: 30rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f4ff 0%, #f5f5f5 100%);
}

.guide-card {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.08);
}

.guide-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #2c3e50;
  margin-bottom: 12rpx;
}

.guide-subtitle {
  font-size: 28rpx;
  color: #7f8c8d;
}

.form-item {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.08);
}

.form-item .label {
  font-size: 30rpx;
  font-weight: 600;
  color: #2c3e50;
  margin-bottom: 12rpx;
}

.form-item .hint-text {
  font-size: 26rpx;
  color: #95a5a6;
  margin-bottom: 16rpx;
}

.form-item textarea {
  width: 100%;
  min-height: 180rpx;
  font-size: 30rpx;
  line-height: 1.6;
  color: #2c3e50;
}

.picker {
  font-size: 30rpx;
  color: #2c3e50;
  padding: 20rpx 0;
  border: 1rpx solid #eee;
  border-radius: 12rpx;
  padding-left: 20rpx;
}

.remaining-hint {
  font-size: 26rpx;
  color: #666;
  text-align: center;
  margin-bottom: 30rpx;
}

.remaining-hint .number {
  color: #667eea;
  font-weight: bold;
  font-size: 32rpx;
}

.remaining-hint.no-quota {
  color: #ff4d4f;
}

.submit-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-radius: 50rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.3);
}

.submit-btn.disabled {
  background: #ccc;
  box-shadow: none;
}

.result-area {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.08);
}

.result-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2c3e50;
  margin-bottom: 20rpx;
}

.result-content {
  font-size: 30rpx;
  line-height: 1.8;
  color: #4a4a4a;
  white-space: pre-wrap;
  margin-bottom: 24rpx;
}

.disclaimer-note {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #eee;
  font-size: 24rpx;
  color: #999;
}

.copy-btn {
  background: #f0f4ff;
  color: #667eea;
  border: 1rpx solid #dcdefe;
  border-radius: 50rpx;
  height: 70rpx;
  line-height: 70rpx;
  font-size: 28rpx;
}

.copy-btn:active {
  background: #e0e7ff;
}

.loading {
  text-align: center;
  color: #95a5a6;
  font-size: 28rpx;
  padding: 40rpx 0;
}
